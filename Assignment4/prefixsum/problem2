arr = [2,4,1,7,3]
n = len(arr)

# Create prefix array
prefix = [0] * n

prefix[0] = arr[0]

# Build prefix sum
for i in range(1, n):
    prefix[i] = prefix[i-1] + arr[i]

print(prefix)   # [2, 6, 7, 14, 17]

L = 1
R = 3

# Range sum
if L == 0:
    answer = prefix[R]
else:
    answer = prefix[R] - prefix[L-1]

print(answer)






