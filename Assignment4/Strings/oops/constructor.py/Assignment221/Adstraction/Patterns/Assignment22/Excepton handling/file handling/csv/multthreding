# retry mechnasium
import threading
import time

def task():
    retries = 3

    for attempt in range(1, retries + 1):
        try:
            print("Attempt:", attempt)

            if attempt < 3:
                raise Exception("Failed")

            print("Success")
            break

        except Exception as e:
            print("Error:", e)
            time.sleep(2)

t1 = threading.Thread(target=task)

t1.start()

