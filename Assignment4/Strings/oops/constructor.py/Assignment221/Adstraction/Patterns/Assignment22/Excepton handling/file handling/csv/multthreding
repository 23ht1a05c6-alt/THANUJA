import threading
import time

def download_file(file_name):
    print("Starting download:", file_name)
    time.sleep(2)  # simulate download time
    print("Completed download:", file_name)

files = ["file1.mp4", "file2.mp3", "file3.pdf"]

threads = []

for file in files:
    t = threading.Thread(target=download_file, args=(file,))
    threads.append(t)
    t.start()

for t in threads:
    t.join()

print("All downloads completed")


